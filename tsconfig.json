{
  "compilerOptions": {
    "inlineSourceMap": true,
    "inlineSources": true,
    "module": "ESNext",
    "target": "ES2020",
    "allowImportingTsExtensions": true,
    "allowJs": true,
    "importHelpers": true,
    "isolatedModules": true,
    "strictNullChecks": true,
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM"]
  },
  "include": ["**/*.ts"]
}
